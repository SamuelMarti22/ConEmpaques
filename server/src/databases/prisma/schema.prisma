generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Enums

enum Role {
  ADMIN
  REPARTIDOR
}

enum EstadoRuta {
  PENDIENTE
  EN_PROCESO
  ENTREGADA
  CANCELADA
}


// Modelos

model Usuario {
  id            Int              @id @default(autoincrement())
  nombre        String
  email         String           @unique
  password      String           
  rol           Role
  activo        Boolean          @default(true)
  createdAt     DateTime         @default(now()) @map("created_at")

  disponibilidades Disponibilidad[]
  rutas            Ruta[]

  @@map("usuario") 
}

model Disponibilidad {
  id          Int      @id @default(autoincrement())
  usuarioId   Int      @map("usuarioID")
  diaSemana   Int      @map("diaDeSemana") 
  horaInicio  String
  horaFin     String

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("disponibilidad")
}

model Ruta {
  id             Int        @id @default(autoincrement())
  repartidorId   Int        @map("repartidor_id")
  fechaReparto   DateTime   @map("fecha_reparto")
  estadoRuta     EstadoRuta @map("estado_ruta")
  horaEntrega    String     @map("horaEntrega")
  createdAt      DateTime   @default(now()) @map("created_a")

  repartidor Usuario @relation(fields: [repartidorId], references: [id])

  @@map("rutas")
}